# Copy to backend/.env for local dev. Never commit a real .env.
DJANGO_SETTINGS_MODULE=algomate.settings.development
DJANGO_SECRET_KEY=replace-me-with-a-50-char-random-string
DJANGO_DEBUG=True
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1
DATABASE_URL=postgres://algomate:algomate@localhost:5432/algomate
CORS_ALLOWED_ORIGINS=http://localhost:5173,http://127.0.0.1:5173
JWT_ACCESS_MINUTES=15
JWT_REFRESH_DAYS=7

# Email (transactional). Production sends via Resend SMTP; dev prints to console.
EMAIL_HOST=smtp.resend.com
EMAIL_PORT=587
EMAIL_HOST_USER=resend
EMAIL_HOST_PASSWORD=your-resend-api-key
DEFAULT_FROM_EMAIL=Algomate <noreply@algomate.ro>
FRONTEND_BASE_URL=https://laborator.algomate.ro
